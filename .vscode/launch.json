    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Default",
            "type": "debugpy",
            "request": "launch",
            "program": "src/sub_convert/__main__.py",
            "console": "integratedTerminal",
            "args":  ["-d", "-o"]
        },
        {
            "name": "Python Debugger: With options",
            "type": "debugpy",
            "request": "launch",
            "program": "src/sub_convert/__main__.py",
            "console": "integratedTerminal",
            "args":  ["-d", "-o", "-p", "smb/jellyfin/shows/Terror in Resonance (2014)", "-cw", "1", "-ow", "2", "-lw", "2" , "-om", "PaddleModelCore"]
        },
        {
            "name": "Python Debugger: Older/younger check",
            "type": "debugpy",
            "request": "launch",
            "program": "src/sub_convert/__main__.py",
            "console": "integratedTerminal",
            "args":  ["-a", "s+1", "-s"]
        },
        {
            "name": "Python Debugger: Adjacent files check",
            "type": "debugpy",
            "request": "launch",
            "program": "src/sub_convert/__main__.py",
            "console": "integratedTerminal",
            "args":  ["-s"]
        },
        {
            "name": "Python Debugger: Batchsize",
            "type": "debugpy",
            "request": "launch",
            "program": "src/sub_convert/__main__.py",
            "console": "integratedTerminal",
            "args":  ["-b", "8", "-o", "-om", "PaddleModelCore"]
        },
    ]
}